{
  "name": "opencode-memory",
  "version": "0.1.0",
  "description": "Persistent memory for OpenCode — auto-saves session context, enables cross-session recall with global index and per-project session files",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "memory",
    "persistent",
    "context",
    "recall",
    "session"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omegaleon/opencode-memory.git"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.10",
    "@types/bun": "^1.3.1",
    "typescript": "^5.8.0"
  }
}
